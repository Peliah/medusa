#!/bin/sh
set -e

FIXED=0
FAILED=0

# в”Ђв”Ђ Detect repo type в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
IS_PYTHON=0
IS_NODE=0
[ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ] && IS_PYTHON=1
[ -f "package.json" ] && IS_NODE=1

# в”Ђв”Ђ File patterns to scan (by repo type) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ "$IS_PYTHON" -eq 1 ] && [ "$IS_NODE" -eq 0 ]; then
  CONFIG_PATTERN="-name '*.py' -o -name 'pyproject.toml' -o -name 'setup.cfg' -o -name 'conftest.py' -o -name 'Makefile'"
elif [ "$IS_PYTHON" -eq 1 ] && [ "$IS_NODE" -eq 1 ]; then
  CONFIG_PATTERN="-name '*.mjs' -o -name '*.cjs' -o -name '*.config.*' -o -name 'postcss*' -o -name '*.py' -o -name 'pyproject.toml'"
else
  CONFIG_PATTERN="-name '*.mjs' -o -name '*.cjs' -o -name '*.config.*' -o -name 'postcss*'"
fi

STAGED=$(git diff --cached --name-only)

# в”Ђв”Ђ Helper: strip long-line injection from a file в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
LONG_LINE_EXCLUDE="pnpm-lock.yaml|yarn.lock|package-lock.json|.*\.min\.js|.*\.min\.css|.*\.map|.*\.lockb|.*\.svg|.*\.md|.*\.png|.*\.jpe?g|.*\.ico"

fix_long_lines() {
  file="$1"
  # Truncate any line over 200 chars to the first 200 characters.
  # This removes the hidden payload while keeping the legitimate code intact
  # since real config lines are never this long.
  awk 'length > 200 { print substr($0, 1, 200); next } { print }' "$file" > "${file}.cleaned"
  mv "${file}.cleaned" "$file"
}

# в”Ђв”Ђ Helper: remove createRequire shim lines в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
fix_create_require() {
  file="$1"
  grep -v "createRequire\|from 'module'" "$file" > "${file}.cleaned"
  mv "${file}.cleaned" "$file"
}

# в”Ђв”Ђ Scan staged files в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
for file in $STAGED; do
  [ -f "$file" ] || continue

  # в”Ђв”Ђ Check 1: Long lines (the hiding technique) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  BASENAME=$(basename "$file")
  case "$file" in
    */components/ui/*)
      : # vendored shadcn components вЂ” long className/cva strings are expected
      ;;
    app/*|components/*|hooks/*|lib/*)
      case "$file" in
        *.ts|*.tsx|*.js|*.jsx)
          # Hand-written source: never auto-truncate вЂ” that corrupts real code.
          LONG_LINE=$(awk 'length > 200 && /className/ { print NR; exit }' "$file")
          if [ -n "$LONG_LINE" ]; then
            echo "вќЊ [long-className] $file:$LONG_LINE вЂ” className line exceeds 200 chars."
            echo "   Split it across cn() args so each line stays short."
            FAILED=1
          fi
          ;;
      esac
      ;;
    *)
      if echo "$BASENAME" | grep -qE "^($LONG_LINE_EXCLUDE)$"; then
        : # excluded file type (lockfiles, minified, maps, svg) вЂ” skip silently
      elif awk 'length > 200 { found=1; exit } END { exit !found }' "$file"; then
        echo "вљ пёЏ  [long-line] $file вЂ” injected payload detected, auto-fixing..."
        fix_long_lines "$file"
        git add "$file"
        FIXED=1
      fi
      ;;
  esac

  # в”Ђв”Ђ Check 2: createRequire in a config file в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if echo "$file" | grep -qE '\.(mjs|cjs|js|ts)$|postcss|config'; then
    if grep -qE "createRequire|from 'module'" "$file" 2>/dev/null; then
      echo "вљ пёЏ  [createRequire] $file вЂ” removing shim lines, auto-fixing..."
      fix_create_require "$file"
      git add "$file"
      FIXED=1
    fi
  fi

  # в”Ђв”Ђ Check 3: Obfuscation patterns вЂ” cannot safely auto-fix, block commit в”Ђв”Ђв”Ђв”Ђ
  # These patterns may appear inside legitimate string content (tests, docs).
  # A human must review before committing.
  for pattern in "String\.fromCharCode" "global\[" "_\\\$_[0-9a-zA-Z]" "eval\s*\(" "Function\s*\("; do
    if grep -qE "$pattern" "$file" 2>/dev/null; then
      echo "вќЊ [obfuscation] $file matches forbidden pattern: $pattern"
      echo "   Auto-fix is not safe here вЂ” review the file manually."
      FAILED=1
    fi
  done

  # в”Ђв”Ђ Check 4: postcss.config.mjs size (Node repos only) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if [ "$IS_NODE" -eq 1 ] && echo "$file" | grep -q "postcss"; then
    SIZE=$(wc -c < "$file")
    if [ "$SIZE" -gt 500 ]; then
      echo "вљ пёЏ  [file-size] $file is $SIZE bytes вЂ” likely injected, auto-fixing..."
      # Restore to the known-good minimal config
      cat > "$file" << 'EOF'
const config = {
  plugins: {
    "@tailwindcss/postcss": {},
  },
};

export default config;
EOF
      git add "$file"
      FIXED=1
    fi
  fi

  # в”Ђв”Ђ Check 5: Python-specific вЂ” no exec/eval/compile in config files в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  if [ "$IS_PYTHON" -eq 1 ] && echo "$file" | grep -qE 'pyproject\.toml|setup\.(py|cfg)|conftest\.py'; then
    for pattern in "exec\s*\(" "compile\s*\(" "__import__" "subprocess"; do
      if grep -qE "$pattern" "$file" 2>/dev/null; then
        echo "вќЊ [python-injection] $file matches forbidden pattern: $pattern"
        echo "   Review manually вЂ” auto-fix is not safe for Python config files."
        FAILED=1
      fi
    done
  fi
done

# в”Ђв”Ђ Summary в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
if [ "$FIXED" -eq 1 ]; then
  echo ""
  echo "рџ”§ Auto-fixes were applied and re-staged."
  echo "   Run 'git diff --cached' to review what changed before your commit proceeds."
fi

if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "вќЊ Commit blocked. Resolve the issues above manually, then re-commit."
  exit 1
fi

# в”Ђв”Ђ lint-staged в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
echo ""
echo "рџ§№ Running lint-staged on staged files..."
if pnpm exec lint-staged; then
  echo "вњ… lint-staged passed вЂ” proceeding with commit."
else
  echo "вќЊ lint-staged failed вЂ” fix the issues above, re-stage, then commit again."
  exit 1
fi

exit 0
